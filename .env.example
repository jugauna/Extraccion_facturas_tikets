# Copiar a .env y completar (no commitear .env)
# Backend Cloud Run / local
AUTODOC_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL_VISION=gpt-4o
CORS_ORIGINS=https://tu-sitio-wordpress.com
# URL pública del servicio (sin / final) para enlaces de curación en correos
PUBLIC_BASE_URL=
# Datos persistentes: gold_dataset + curation_pending (relativo al cwd, en Docker /app/data)
DATA_DIR=data
# Opcional: bucket GCS para sesiones de curación compartidas entre réplicas de Cloud Run (nombre del bucket, sin gs://)
CURATION_PENDING_GCS_BUCKET=
# Prefijo de objetos en ese bucket (por defecto curation_pending)
CURATION_PENDING_GCS_PREFIX=curation_pending
ETHICS_SIMILARITY_REVIEW_THRESHOLD=0.78
# Tras "Confirmar" en la UI de curación, POST JSON a n8n (flujo persistencia): Drive + Sheets + mail al Jefe de Contable
PERSIST_WEBHOOK_URL=
PERSIST_WEBHOOK_SECRET=

# n8n / integraciones (referencia)
# Cloud Run — servicio FastAPI (sin barra final). Tu despliegue actual:
AUTODOC_CLOUD_RUN_URL=https://extraccion-facturas-tikets-816080222172.southamerica-east1.run.app
# Si usás el workflow autodoc_v2_base (/process-ticket) y es el mismo servicio, misma URL:
AUTODOC_BACKEND_URL=https://extraccion-facturas-tikets-816080222172.southamerica-east1.run.app
X_AUTODOC_SECRET=
GOOGLE_SHEET_ID=
HITL_APPROVER_EMAIL=
