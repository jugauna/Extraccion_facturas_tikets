    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const wh = $('Webhook_Ingest').first();\nconst body = wh.json.body || wh.json;\nconst user_notes = String(body.user_notes || body.notes || '');\nconst idempotency_key = $execution.id;\nconst bin = wh.binary?.file || wh.binary?.image || wh.binary?.data;\nif (!bin) {\n  throw new Error('Falta archivo: enviá multipart con campo \"file\" o \"image\" (imagen o PDF).');\n}\nreturn [{ json: { idempotency_key, user_notes, hitl_status: 'PENDING' }, binary: { file: bin } }];"
      },
      "id": "code-attach-binary",
      "name": "Code_Reattach_File",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-960, 200],
      "notesInFlow": true,
      "notes": "Lee user_notes del body. Binario: file | image | data."
