            { "id": "c20", "name": "Importe Percep 3", "type": "string", "value": "={{ $json.sheets_rows[0][\"Importe Percep 3\"] ?? \"\" }}" },
            { "id": "c21", "name": "Iva Total", "type": "string", "value": "={{ $json.sheets_rows[0][\"Iva Total\"] ?? \"\" }}" },
            { "id": "c22", "name": "Cantidad", "type": "string", "value": "={{ $json.sheets_rows[0].Cantidad ?? \"\" }}" },
            { "id": "c23", "name": "Compliance_Score", "type": "string", "value": "={{ String($json.Compliance_Score) }}" },
