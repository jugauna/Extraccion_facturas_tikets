    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "man",
              "name": "manual_etica",
              "type": "string",
              "value": "MANUAL DE ÉTICA (TEXTUAL FIJO – REEMPLAZAR POR POLÍTICA REAL).\n\n1) Todos los gastos deben ser razonables, necesarios para el negocio y respaldados por comprobante hábil.\n2) No se autorizan pagos en efectivo sin trazabilidad ni factura.\n3) Queda prohibido solicitar o aceptar sobornos, comisiones indebidas o ventajas personales ligadas a proveedores.\n4) Los viáticos deben cumplir topes internos y política de medios de pago corporativos.\n5) Cualquier regalo o cortesía debe reportarse y evaluarse según política anticorrupción.\n6) Los datos personales de terceros obtenidos en comprobantes deben tratarse con confidencialidad.\n7) Ante duda de clasificación contable o imputación, debe escalarse a Finanzas antes de comprometer fondos."
            }
          ]
        },
        "options": {}
      },
      "id": "set-ethics",
      "name": "Set_Ethics_Manual",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-480, 200]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const apiKey = $env.OPENAI_API_KEY;\nif (!apiKey) throw new Error('Configure OPENAI_API_KEY en el entorno de n8n');\nconst ethics = $('Set_Ethics_Manual').first().json.manual_etica;\nconst row = $input.first().json;\nconst extracted = JSON.stringify(row.sheets_rows || []);\nfunction cosine(a, b) {\n  let d = 0, na = 0, nb = 0;\n  for (let i = 0; i < a.length; i++) { d += a[i] * b[i]; na += a[i] * a[i]; nb += b[i] * b[i]; }\n  return d / (Math.sqrt(na) * Math.sqrt(nb) + 1e-9);\n}\nconst chunks = ethics.split(/\\n\\n+/).map(s => s.trim()).filter(Boolean).slice(0, 24);\nconst input = [extracted, ...chunks];\nconst res = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.openai.com/v1/embeddings',\n  headers: { Authorization: 'Bearer ' + apiKey, 'Content-Type': 'application/json' },\n  body: { model: 'text-embedding-3-small', input },\n  json: true,\n});\nconst vec = res.data.sort((x, y) => x.index - y.index).map(d => d.embedding);\nconst v0 = vec[0];\nlet best = -1;\nlet idx = 0;\nfor (let i = 1; i < vec.length; i++) {\n  const c = cosine(v0, vec[i]);\n  if (c > best) { best = c; idx = i - 1; }\n}\nconst Compliance_Score = Math.max(0, Math.min(100, Math.round(best * 100)));\nconst Compliance_Notes = `RAG-lite: mayor similitud coseno con fragmento ${idx} del manual (embeddings OpenAI).`;\nreturn [{ json: { ...row, Compliance_Score, Compliance_Notes, rag_best_cosine: best } }];"
      },
